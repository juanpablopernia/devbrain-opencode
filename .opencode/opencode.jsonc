{
  "$schema": "https://opencode.ai/config.json",

  // Instrucciones adicionales que OpenCode puede incluir como reglas de proyecto.
  // Para ahorrar contexto, se carga AGENTS.md y el índice; luego se leen más archivos según la tarea.
  "instructions": [
    "AGENTS.md",
    "docs/brain/CONTEXT_INDEX.md"
  ],

  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls*": "allow",
      "pwd": "allow"
    },
    "webfetch": "ask",
    "websearch": "ask"
  }
}
